# Copy to .env.local and fill in. Never commit real keys.

# --- Supabase ---
# From Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Do NOT expose to the browser. Used by the cron to write snapshots.
SUPABASE_SERVICE_ROLE_KEY=

# --- Market data ---
# Financial Modeling Prep (primary). Free tier: https://financialmodelingprep.com
FMP_API_KEY=
# Alpha Vantage (fallback). https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# --- Cron ---
# Shared secret checked by /api/cron/snapshot. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# --- Email (SendGrid) ---
# Server-only. Used by /api/auth/email-link to deliver magic-link
# sign-in emails. If either is missing, /admin/login returns 503.
# Free tier: 100 emails/day. Get the API key at
#   https://app.sendgrid.com/settings/api_keys
# Verify a sender email (any address, no domain required) at
#   https://app.sendgrid.com/settings/sender_auth/senders
SENDGRID_API_KEY=
# Sender address. Must match a verified single sender, e.g.
#   SENDGRID_FROM="CIMG Portfolio <team@example.com>"
# The address portion must be an address you clicked the verify link on.
SENDGRID_FROM=
