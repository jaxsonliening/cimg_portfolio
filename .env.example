# Copy to .env.local and fill in. Never commit real keys.

# --- Supabase ---
# From Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Do NOT expose to the browser. Used by the cron to write snapshots.
SUPABASE_SERVICE_ROLE_KEY=

# --- Market data ---
# Financial Modeling Prep (primary). Free tier: https://financialmodelingprep.com
FMP_API_KEY=
# Alpha Vantage (fallback). https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# --- Cron ---
# Shared secret checked by /api/cron/snapshot. Generate with `openssl rand -hex 32`.
CRON_SECRET=
